{
    "name": "gkx-monorepo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:web": "npm run dev -w web",
        "dev:api": "npm run start:dev -w api",
        "build:web": "npm run build -w web",
        "build:api": "npm run build -w api",
        "lint:web": "npm run lint -w web",
        "lint:api": "npm run lint -w api",
        "test:web": "npm run test -w web",
        "test:api": "npm run test -w api",
        "build": "npm run build:web && npm run build:api",
        "lint": "npm run lint:web && npm run lint:api",
        "test": "npm run test:web && npm run test:api"
    }
}